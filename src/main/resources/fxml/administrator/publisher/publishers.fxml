<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER"
      spacing="20"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pl.controller.administrator.publisher.PublisherController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="30"/>
    </padding>

    <children>

        <Label text="Wydawnictwa">
            <font>
                <Font size="24.0"/>
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT"
              spacing="20"
              VBox.vgrow="ALWAYS">

            <!-- TABELA -->
            <TableView fx:id="tableViewId"
                       prefHeight="400"
                       HBox.hgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="pubId"
                                 prefWidth="80"
                                 text="ID"/>

                    <TableColumn fx:id="pubNameId"
                                 prefWidth="300"
                                 text="Nazwa"/>
                </columns>

                <padding>
                    <Insets bottom="5.0"
                            left="5.0"
                            right="5.0"
                            top="5.0"/>
                </padding>

            </TableView>

            <!-- PANEL BOCZNY -->
            <VBox alignment="TOP_CENTER"
                  prefWidth="250"
                  spacing="12"
                  style="-fx-border-color: #ccc; -fx-border-width: 0 0 0 1; -fx-padding: 15;">

                <Label text="Szczegóły">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </Label>

                <Label text="ID:"/>
                <Label fx:id="idLabel"
                       text="-"/>

                <Label text="Nazwa wydawnictwa:"/>

                <TextField fx:id="nameField"
                           prefWidth="180"
                           promptText="Wpisz nazwę"/>

                <!-- DODAWANIE OD RAZU POD FIELDEM -->
                <Button fx:id="addPublisherBtn"
                        mnemonicParsing="false"
                        prefWidth="160.0"
                        text="Dodaj wydawnictwo"/>

                <Region prefHeight="20.0"/>

                <VBox alignment="CENTER"
                      spacing="10">

                    <Button fx:id="saveBtn"
                            prefWidth="140"
                            text="Zapisz"/>

                    <Button fx:id="deleteBtn"
                            disable="true"
                            prefWidth="140"
                            text="Usuń"/>

                    <CheckBox fx:id="checkId"
                              text="Potwierdź operację"/>

                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

            </VBox>

        </HBox>

    </children>

</VBox>