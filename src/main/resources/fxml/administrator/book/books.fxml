<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.controller.administrator.book.BookController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <children>

        <Label text="Książki">
            <font>
                <Font size="24" />
            </font>
        </Label>

        <HBox spacing="20" VBox.vgrow="ALWAYS">

            <TableView fx:id="tableViewId" prefHeight="500" HBox.hgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="bookIdColumn" prefWidth="60" text="ID" />

                    <TableColumn fx:id="titleColumn" prefWidth="250" text="Tytuł" />

                    <TableColumn fx:id="isbnColumn" prefWidth="150" text="ISBN" />

                    <TableColumn fx:id="yearColumn" prefWidth="100" text="Rok" />

                    <TableColumn fx:id="availableColumn" prefWidth="100" text="Dostępna" />

                    <TableColumn fx:id="publisherColumn" prefWidth="180" text="Wydawnictwo" />

                </columns>

            </TableView>

            <VBox alignment="TOP_CENTER" prefWidth="320" spacing="12" style="-fx-border-color: #ccc; -fx-border-width: 0 0 0 1; -fx-padding: 15;">

                <Label text="Szczegóły">
                    <font>
                        <Font size="16" />
                    </font>
                </Label>

                <Label text="ID" />
                <Label fx:id="idLabel" text="-" />

                <Label text="Tytuł" />
                <Label fx:id="titleLabel" text="-" />

                <Label text="ISBN" />
                <Label fx:id="isbnLabel" text="-" />

                <Label text="Rok wydania" />
                <Label fx:id="yearLabel" text="-" />

                <Label text="Strony" />
                <Label fx:id="pagesLabel" text="-" />

                <Label text="Dostępność" />
                <Label fx:id="availableLabel" text="-" />

                <Label text="Wydawnictwo" />
                <Label fx:id="publisherLabel" text="-" />

                <Label text="Lokalizacja" />
                <Label fx:id="locationLabel" text="-" />

                <Label text="Gatunek" />
                <Label fx:id="genreLabel" text="-" />

                <Separator />

                <Label text="Autorzy" />
                <ListView fx:id="authorsListView" prefHeight="120" />

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="addBookBtn" prefHeight="45" prefWidth="160" text="Dodaj książkę" />

            </VBox>

        </HBox>

    </children>
</VBox>
