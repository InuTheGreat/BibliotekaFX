<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pl.controller.administrator.BorrowingController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="30"/>
    </padding>

    <Label text="Aktywne wypożyczenia">
        <font>
            <Font size="24"/>
        </font>
    </Label>

    <TableView fx:id="tableViewId" prefHeight="500" maxWidth="Infinity">
        <columns>
            <TableColumn fx:id="borrowingIdColumn" prefWidth="60" text="ID"/>
            <TableColumn fx:id="titleColumn" prefWidth="250" text="Tytuł"/>
            <TableColumn fx:id="isbnColumn" prefWidth="150" text="ISBN"/>
            <TableColumn fx:id="borrowDateColumn" prefWidth="150" text="Data wypożyczenia"/>
            <TableColumn fx:id="readerNameColumn" prefWidth="200" text="Czytelnik"/>
            <TableColumn fx:id="readerEmailColumn" prefWidth="200" text="Email"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <CheckBox fx:id="checkId" text="Potwierdź zwrot"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="returnBtn" prefHeight="40" prefWidth="160" text="Zatwierdź zwrot"/>
    </HBox>

</VBox>