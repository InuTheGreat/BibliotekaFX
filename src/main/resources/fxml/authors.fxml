<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.controller.AuthorController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <children>

        <Label prefHeight="20.0" prefWidth="82.0" text="Autorzy">
         <font>
            <Font size="24.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin></Label>

        <HBox alignment="CENTER_LEFT" spacing="20" VBox.vgrow="ALWAYS">

            <!-- TABELA -->
            <TableView fx:id="tableViewId" maxHeight="600.0" maxWidth="850.0" prefHeight="400" prefWidth="700.0" HBox.hgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="autId" prefWidth="80" text="ID" />
                    <TableColumn fx:id="autNamId" prefWidth="180" text="Imię" />
                    <TableColumn fx:id="autSurnId" prefWidth="220" text="Nazwisko" />
                </columns>
            <padding>
               <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </padding>

            </TableView>

            <!-- PANEL -->
            <VBox alignment="TOP_CENTER" prefWidth="150" spacing="15">

                <Label text="Akcje">
               <font>
                  <Font size="16.0" />
               </font></Label>

                <Button fx:id="deleteBtn" prefWidth="120" text="Usuń" />
            <CheckBox fx:id="checkId" mnemonicParsing="false" prefHeight="18.0" prefWidth="125.0" text="Potwierdź operację" VBox.vgrow="SOMETIMES" />

            </VBox>

        </HBox>

    </children>
</VBox>
