<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pl.controller.pane.top.setup.SetupController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>

        <Label text="Zmiana hasła">
            <font>
                <Font size="18"/>
            </font>
        </Label>

        <VBox spacing="10" alignment="CENTER_LEFT">

            <Label text="Nowe hasło:"/>
            <PasswordField fx:id="newPasswordField" prefWidth="220"/>

            <Label text="Powtórz hasło:"/>
            <PasswordField fx:id="repeatPasswordField" prefWidth="220"/>

        </VBox>

        <HBox spacing="15" alignment="CENTER">

            <Button fx:id="saveBtn" text="Zapisz" prefWidth="100"/>
            <Button fx:id="cancelBtn" text="Anuluj" prefWidth="100"/>

        </HBox>

    </children>
</VBox>