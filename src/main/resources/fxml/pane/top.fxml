<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.Region?>

<ToolBar maxHeight="600.0" prefHeight="75.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.controller.pane.top.PaneTopController">
  <items>
    <Button fx:id="startBoardBtn" mnemonicParsing="false" prefHeight="62.0" prefWidth="157.0" text="Ekran Startowy">
         <padding>
            <Insets bottom="5.0" />
         </padding></Button>
      <Button fx:id="setupBtn" mnemonicParsing="false" prefHeight="62.0" prefWidth="114.0" text="Ustawienia">
         <padding>
            <Insets bottom="5.0" />
         </padding></Button>
      <Region maxHeight="40.0" minHeight="40.0" prefHeight="62.0" prefWidth="102.0">
         <padding>
            <Insets bottom="5.0" />
         </padding></Region>
      <Button fx:id="logOutBtn" mnemonicParsing="false" prefHeight="62.0" prefWidth="86.0" text="Wyloguj">
         <padding>
            <Insets bottom="5.0" />
         </padding></Button>
      <Region prefHeight="62.0" prefWidth="15.0" />
      <Button fx:id="tunOffBtn" mnemonicParsing="false" prefHeight="62.0" prefWidth="175.0" text="Zamknij aplikację">
         <padding>
            <Insets bottom="5.0" />
         </padding></Button>
  </items>
</ToolBar>
